# Application
APP_ENV=development
APP_PORT=8080
APP_SECRET=replace-with-64-char-random-hex-string

# PostgreSQL (Neon in prod)
DATABASE_URL=postgres://user:password@localhost:5432/publishing?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-another-64-char-random-hex-string
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=publishing-platform-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=50

# Admin seed (first boot only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback
ADMIN_ALLOWED_EMAILS=admin@example.com,you@yourdomain.com